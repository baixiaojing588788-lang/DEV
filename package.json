{
  "name": "little-mao-puppy",
  "version": "0.1.0",
  "description": "桌面宠物 - 小鸡毛",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.littlemao.puppy",
    "productName": "我的桌宠",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "chat-preload.js",
      "settings-preload.js",
      "index.html",
      "chat.html",
      "settings.html",
      "assets/**/*",
      "!assets/**/*.webp",
      "!assets/.DS_Store"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.entertainment",
      "icon": "assets/icon.icns",
      "identity": null
    }
  },
  "allowScripts": {
    "electron@33.4.11": true
  }
}
